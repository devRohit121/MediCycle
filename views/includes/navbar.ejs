<nav class="bg-white border-b shadow-sm sticky top-0 z-50">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">

    <!-- Brand -->
    <a href="/batches"
       class="flex items-center gap-2 text-xl font-bold text-gray-800">

      <img src="/logo/flogo.png" 
        class="h-8 sm:h-10 md:h-12 lg:h-14 w-auto object-contain"/>

    </a>

    <!-- Mobile button -->
    <button id="menuBtn"
            class="md:hidden text-gray-700 focus:outline-none">
      <i class="fa-solid fa-bars text-xl"></i>
    </button>

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-4 text-sm">

      <% if (!currentUser) { %>

        <a href="/batches" class="text-gray-600 hover:text-gray-900">Home</a>

        <a href="/signup"
           class="px-4 py-2 rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700">
          Sign up
        </a>

        <a href="/login"
           class="px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700">
          Log in
        </a>

      <% } else { %>
        <a href="/batches" class="text-gray-600 hover:text-gray-900">Home</a>

        <% if (currentUser.role === "admin") { %>
          <a href="/admin" class="text-gray-600 hover:text-gray-900">
          Dashboard
        </a>
      <% } %>

        <% if (currentUser.role === "seller") { %>
          <a href="/batches/new" class="text-gray-600 hover:text-gray-900">
            Add Listing
          </a>

          <a href="/seller/dashBoard" class="text-gray-600 hover:text-gray-900">
            Dashboard
          </a>
        <% } %>

        <% if (currentUser.role === "buyer") { %>
          <a href="/orders/my" class="text-gray-600 hover:text-gray-900">
            Orders
          </a>
        <% } %>

        <% if (currentUser.role !== "admin") { %>
          <a href="/orders/notifications"
             class="relative text-gray-600 hover:text-gray-900">

            Notifications

            <% if (typeof notificationCount !== "undefined" && notificationCount > 0) { %>
              <span class="absolute -top-2 -right-3 bg-red-500 text-white text-xs px-2 py-0.5 rounded-full">
                <%= notificationCount %>
              </span>
            <% } %>

          </a>
        <% } %>

        <a href="/logout"
           class="px-4 py-2 rounded-lg bg-red-50 text-red-600 hover:bg-red-100">
          Logout
        </a>

      <% } %>

    </div>

  </div>

  <!-- Mobile Menu -->
  <div id="mobileMenu"
       class="hidden md:hidden px-4 pb-4 space-y-3 text-sm border-t">

    <% if (!currentUser) { %>

      <a href="/batches" class="block text-gray-700">Home</a>

      <a href="/signup" class="block bg-gray-100 px-3 py-2 rounded-lg">Sign up</a>

      <a href="/login" class="block bg-blue-600 text-white px-3 py-2 rounded-lg">Log in</a>

    <% } else { %>

      <% if (currentUser.role !== "seller" && currentUser.role !== "buyer") { %>
        <a href="/admin" class="block text-gray-700">DashBoard</a>
      <% } %>

      <% if (currentUser.role === "seller") { %>
        <a href="/batches/new" class="block text-gray-700">Add Listing</a>
        <a href="/seller/dashBoard" class="block text-gray-700">Dashboard</a>
      <% } %>

      <% if (currentUser.role === "buyer") { %>
        <a href="/orders/my" class="block text-gray-700">Orders</a>
      <% } %>

      <% if (currentUser.role !== "admin") { %>
        <a href="/orders/notifications" class="block text-gray-700">
          Notifications
        </a>
      <% } %>

      <a href="/logout" class="block text-red-600">Logout</a>

      

    <% } %>

  </div>

</nav>

<!-- JS Toggle -->
<script>
  const btn = document.getElementById("menuBtn");
  const menu = document.getElementById("mobileMenu");

  btn?.addEventListener("click", () => {
    menu.classList.toggle("hidden");
  });
</script>