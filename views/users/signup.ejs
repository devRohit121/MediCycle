<% layout("layouts/boilerplate") %>

<div class="min-h-screen flex items-center justify-center bg-gray-100">
  <div class="bg-white p-8 rounded-xl shadow-lg w-full max-w-lg">

    <h2 class="text-2xl font-bold text-center mb-6">Create Account</h2>

    <form id="signupForm" method="POST" action="/signup" novalidate class="space-y-4 needs-validate">

      <div>
        <input name="username" placeholder="Username" required
          class="w-full border px-3 py-2 rounded-lg focus:ring-2 focus:ring-blue-500">
        <p class="text-red-600 text-sm mt-1 hidden"></p>
      </div>

      <div>
        <input type="email" name="email" placeholder="Email" required
          class="w-full border px-3 py-2 rounded-lg focus:ring-2 focus:ring-blue-500">
        <p class="text-red-600 text-sm mt-1 hidden"></p>
      </div>

      <div> 
        <input id="signupPassword" type="password" name="password" placeholder="Password" required
          class="w-full border px-3 py-2 rounded-lg focus:ring-2 focus:ring-blue-500">
        <p class="text-red-600 text-sm mt-1 hidden"></p>
      </div>

      <div>
        <label class="block text-sm text-gray-700 mb-1">Role</label>
        <select name="role" required
          class="w-full border px-3 py-2 rounded-lg focus:ring-2 focus:ring-blue-500">
          <option value="">Select role</option>
          <option value="seller">Seller</option>
          <option value="buyer">Buyer</option>
        </select>
        <p class="text-red-600 text-sm mt-1 hidden"></p>
      </div>

      <div>
        <input name="organizationName" placeholder="Organization Name" required
          class="w-full border px-3 py-2 rounded-lg focus:ring-2 focus:ring-blue-500">
        <p class="text-red-600 text-sm mt-1 hidden"></p>
      </div>

      <div>
        <input name="phone" placeholder="Phone Number" required
          class="w-full border px-3 py-2 rounded-lg focus:ring-2 focus:ring-blue-500">
        <p class="text-red-600 text-sm mt-1 hidden"></p>
      </div>

      <% if (error) { %>
        <p class="text-red-600 text-sm"><%= error %></p>
      <% } %>

      <button class="w-full bg-green-600 text-white py-2 rounded-lg hover:bg-green-700 transition">
        Sign Up
      </button>

    </form>

    <p class="text-sm text-center mt-4">
      Already have an account?
      <a href="/login" class="text-blue-600 hover:underline">Login</a>
    </p>

  </div>
</div> 