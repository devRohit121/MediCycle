<% layout("layouts/boilerplate") %>

<div class="max-w-3xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Notifications</h1>
    <p class="text-sm text-gray-500">Updates and alerts related to your activity</p>
  </div>

  <% if (notifications.length === 0) { %>

    <!-- Empty State -->
    <div class="bg-white border rounded-xl shadow-sm p-10 text-center">
      <p class="text-gray-500 font-medium">No Notifications</p>
      <p class="text-sm text-gray-400 mt-1">You're all caught up</p>
    </div>

  <% } else { %>

    <div class="space-y-3">

      <% for (let n of notifications) { %>

        <div class="bg-white border rounded-xl shadow-sm p-4 flex items-start justify-between hover:shadow-md transition">

          <!-- Message -->
          <div class="pr-4">
            <p class="text-gray-800 text-sm leading-relaxed">
              <%= n.message %>
            </p>
          </div>

          <!-- Action -->
          <a href="<%= n.link %>"
             class="shrink-0 text-sm font-medium text-blue-600 hover:text-blue-800">
            View →
          </a>

        </div>

      <% } %>

    </div>

  <% } %>

</div>