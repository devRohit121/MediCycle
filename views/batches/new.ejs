<% layout("layouts/boilerplate") %>

<div class="max-w-3xl mx-auto bg-white shadow-lg rounded-xl p-6 mt-6">

    <h2 class="text-2xl font-semibold text-gray-800 mb-6">
        List Your Medicine
    </h2>

    <form method="POST" action="/batches" class="space-y-5 needs-validate" novalidate>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Medicine Name
            </label>
            <input name="batch[name]" 
                   placeholder="Enter medicine name"
                   required
                   class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Category
            </label>
            <select name="batch[category]" 
                    class="w-full px-4 py-2 border rounded-lg bg-white focus:ring-2 focus:ring-blue-500 outline-none">
                <option value="Tablet">Tablet</option>
                <option value="Capsule">Capsule</option>
                <option value="Syrup">Syrup</option>
                <option value="Injection">Injection</option>
                <option value="Ointment">Ointment</option>
            </select>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <div>
                <label class="block text-sm text-gray-700 mb-1">Manufacturer</label>
                <input name="batch[manufacturer]"
                       placeholder="Enter manufacturer" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

            <div>
                <label class="block text-sm text-gray-700 mb-1">Batch No</label>
                <input name="batch[batchNo]"
                       placeholder="Enter batch number" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

            <div>
                <label class="block text-sm text-gray-700 mb-1">Manufacturing Date</label>
                <input type="date"
                       name="batch[manufacturingDate]" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

            <div>
                <label class="block text-sm text-gray-700 mb-1">Expiry Date</label>
                <input type="date"
                       name="batch[expiryDate]" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

            <div>
                <label class="block text-sm text-gray-700 mb-1">Quantity</label>
                <input type="number"
                       name="batch[quantity]"
                       placeholder="Enter quantity" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

            <div>
                <label class="block text-sm text-gray-700 mb-1">Unit Price</label>
                <input type="number"
                       name="batch[unitPrice]"
                       placeholder="Enter unit price" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

            <div>
                <label class="block text-sm text-gray-700 mb-1">Discounted Price</label>
                <input type="number"
                       name="batch[discountedPrice]"
                       placeholder="Enter discounted price" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

            <div>
                <label class="block text-sm text-gray-700 mb-1">Location</label>
                <input name="batch[location]"
                       placeholder="Enter location" required
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

        </div>

        <div class="pt-4">
            <button type="submit"
                    class="w-full md:w-auto px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
                Add Medicine
            </button>
        </div>

    </form>
</div>