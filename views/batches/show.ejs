<% layout("layouts/boilerplate") %>

<form method="GET" action="/batches" 
      class="bg-white shadow-md rounded-xl p-4 mb-6 flex flex-col md:flex-row gap-3 md:items-center md:justify-between">

    <!-- Search -->
    <input 
        type="text"
        name="search"
        value="<%= search || '' %>"
        placeholder="Search medicine..."
        class="w-full md:w-1/3 px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
    />

    <!-- Category -->
    <select 
        name="category"
        class="w-full md:w-1/4 px-4 py-2 border rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500"
    >
        <option value="">All Categories</option>
        <option value="Tablet" <%= category === 'Tablet' ? 'selected' : '' %>>Tablet</option>
        <option value="Capsule" <%= category === 'Capsule' ? 'selected' : '' %>>Capsule</option>
        <option value="Syrup" <%= category === 'Syrup' ? 'selected' : '' %>>Syrup</option>
        <option value="Injection" <%= category === 'Injection' ? 'selected' : '' %>>Injection</option>
        <option value="Ointment" <%= category === 'Ointment' ? 'selected' : '' %>>Ointment</option>
    </select>

    <!-- Button -->
    <button 
        type="submit"
        class="w-full md:w-auto px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition"
    >
        Apply
    </button>
</form>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% for (let batch of allBatches) { %>
        <a href="/batches/<%= batch._id %>"
           class="block bg-white rounded-xl shadow hover:shadow-lg transition p-5 border border-gray-100">

            <div class="space-y-2">
                <h2 class="text-lg font-semibold text-gray-800">
                    <%= batch.name %>
                </h2>

                <p class="text-sm text-gray-600">
                    <span class="font-medium">Category:</span> <%= batch.category %>
                </p>

                <p class="text-sm text-gray-600">
                    <span class="font-medium">Manufacturer:</span> <%= batch.manufacturer %>
                </p>

                <p class="text-sm text-gray-600">
                    <span class="font-medium">Quantity:</span> <%= batch.quantity %>
                </p>

                <p class="text-sm">
                    <span class="line-through text-gray-400">₹<%= batch.unitPrice %></span>
                    <span class="text-green-600 font-semibold ml-2">₹<%= batch.discountedPrice %></span>
                </p>

                <p class="text-xs text-gray-500">
                    📍 <%= batch.location %>
                </p>
            </div>
        </a>
    <% } %>
</div>

<div class="flex justify-center mt-8">
    <div class="flex gap-2 items-center bg-white shadow px-4 py-2 rounded-lg">

        <% if (currentPage > 1) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage-1 %>&search=<%= search || '' %>&category=<%= category || '' %>">
                Prev
            </a>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
            <a class="px-3 py-1 rounded 
                      <%= i === currentPage ? 'bg-blue-600 text-white' : 'hover:bg-gray-100' %>"
               href="?page=<%= i %>&search=<%= search || '' %>&category=<%= category || '' %>">
                <%= i %>
            </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage+1 %>&search=<%= search || '' %>&category=<%= category || '' %>">
                Next
            </a>
        <% } %>

    </div>
</div>