<% layout("layouts/boilerplate") %>

<div class="max-w-6xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Your Orders</h1>
      <p class="text-sm text-gray-500">Track and manage all your purchases</p>
    </div>

    <a href="/cart"
       class="text-sm bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
      Go to Cart
    </a>
  </div>

  <!-- ================= PENDING ================= -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-700 mb-3">Pending Orders</h2>

    <% if (pendingOrders.length > 0) { %>
      <div class="grid md:grid-cols-2 gap-4">

        <% for (let order of pendingOrders) { %>
          <div class="bg-white border rounded-xl shadow-sm p-5">

            <div class="flex justify-between items-start">
              <h3 class="font-semibold text-gray-800">
                <%= order.batch ? order.batch.name : "Batch deleted" %>
              </h3>

              <span class="text-xs px-2 py-1 rounded-full bg-yellow-100 text-yellow-700">
                Pending
              </span>
            </div>

            <div class="mt-3 space-y-1 text-sm text-gray-600">
              <p>Seller: <span class="text-gray-800"><%= order.seller.email %></span></p>
              <p>Quantity: <%= order.quantityOrdered %></p>
              <p>Total: <span class="font-medium">₹<%= order.totalAmount %></span></p>
              <p>Ordered: <%= order.createdAt.toDateString() %></p>
            </div>

          </div>
        <% } %>

      </div>
    <% } else { %>
      <div class="bg-white border rounded-xl p-6 text-sm text-gray-500">
        No pending orders
      </div>
    <% } %>
  </section>

  <!-- ================= PROCESSED ================= -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-700 mb-3">Processed Orders</h2>

    <% if (processedOrders.length > 0) { %>
      <div class="grid md:grid-cols-2 gap-4">

        <% for (let order of processedOrders) { %>

          <div class="bg-white border rounded-xl shadow-sm p-5">

            <div class="flex justify-between items-start">
              <h3 class="font-semibold text-gray-800">
                <%= order.batch ? order.batch.name : "Batch deleted" %>
              </h3>

              <span class="text-xs px-2 py-1 rounded-full
                <%= order.status === 'accepted' || order.status === 'completed'
                  ? 'bg-green-100 text-green-700'
                  : 'bg-red-100 text-red-700' %>">
                <%= order.status %>
              </span>
            </div>

            <div class="mt-3 space-y-1 text-sm text-gray-600">
              <p>Seller: <span class="text-gray-800"><%= order.seller.email %></span></p>
              <p>Quantity: <%= order.quantityOrdered %></p>
              <p>Total: <span class="font-medium">₹<%= order.totalAmount %></span></p>
              <p>Ordered: <%= order.createdAt.toDateString() %></p>
            </div>

            <!-- Actions -->
            <div class="mt-4 flex gap-3">

              <% if(order.status === "accepted") { %>
                <form method="POST" action="/orders/<%=order._id%>/completed?_method=PUT">
                  <button class="px-3 py-2 text-sm bg-green-600 text-white rounded-lg hover:bg-green-700">
                    Mark Completed
                  </button>
                </form>
              <% } else { %>
                <form method="GET" action="/orders/<%=order._id%>/reorder">
                  <button class="px-3 py-2 text-sm bg-gray-600 text-white rounded-lg hover:bg-gray-700">
                    Reorder
                  </button>
                </form>
              <% } %>

            </div>

          </div>

        <% } %>

      </div>
    <% } else { %>
      <div class="bg-white border rounded-xl p-6 text-sm text-gray-500">
        No processed orders
      </div>
    <% } %>
  </section>

  <!-- ================= COMPLETED ================= -->
  <section>
    <h2 class="text-lg font-semibold text-gray-700 mb-3">Completed Orders</h2>

    <% if (completedOrders.length > 0) { %>
      <div class="grid md:grid-cols-2 gap-4">

        <% for (let order of completedOrders) { %>
          <div class="bg-white border rounded-xl shadow-sm p-5 opacity-90">

            <div class="flex justify-between items-start">
              <h3 class="font-semibold text-gray-800">
                <%= order.batch ? order.batch.name : "Batch deleted" %>
              </h3>

              <span class="text-xs px-2 py-1 rounded-full bg-gray-200 text-gray-700">
                Completed
              </span>
            </div>

            <div class="mt-3 space-y-1 text-sm text-gray-600">
              <p>Seller: <span class="text-gray-800"><%= order.seller.email %></span></p>
              <p>Quantity: <%= order.quantityOrdered %></p>
              <p>Total: ₹<%= order.totalAmount %></p>
              <p>Ordered: <%= order.createdAt.toDateString() %></p>
            </div>

          </div>
        <% } %>

      </div>
    <% } else { %>
      <div class="bg-white border rounded-xl p-6 text-sm text-gray-500">
        No completed orders
      </div>
    <% } %>
  </section>

</div>