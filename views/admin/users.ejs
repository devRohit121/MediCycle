<% layout("layouts/boilerplate") %>

<div class="max-w-6xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">All Users</h1>
    <p class="text-sm text-gray-500">Manage platform users</p>
  </div>

  <!-- Grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

    <% users.forEach(user => { %>

      <div class="bg-white border rounded-xl shadow-sm p-5 flex justify-between items-center">

        <!-- User Info -->
        <div>

          <p class="text-sm text-gray-500">Email</p>
          <p class="text-gray-800 font-medium break-all">
            <%= user.email %>
          </p>

          <!-- Role Badge -->
          <div class="mt-2">

            <% if(user.role === "admin") { %>
              <span class="text-xs px-2 py-1 rounded-full bg-purple-100 text-purple-700">
                admin
              </span>
            <% } else if(user.role === "seller") { %>
              <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-700">
                seller
              </span>
            <% } else { %>
              <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700">
                buyer
              </span>
            <% } %>

          </div>

        </div>

        <!-- Delete -->
        <form method="POST"
              action="/admin/users/<%= user._id %>?_method=DELETE"
              onsubmit="return confirm('Delete this user?')">

          <button
            class="text-sm px-3 py-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition">
            Delete
          </button>

        </form>

      </div>

    <% }) %>

  </div>

</div>

<div class="flex justify-center mt-8">
    <div class="flex gap-2 items-center bg-white shadow px-4 py-2 rounded-lg">

        <% if (currentPage > 1) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage-1 %>">
                Prev
            </a>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
            <a class="px-3 py-1 rounded 
                      <%= i === currentPage ? 'bg-blue-600 text-white' : 'hover:bg-gray-100' %>"
               href="?page=<%= i %>">
                <%= i %>
            </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage+1 %>">
                Next
            </a>
        <% } %>

    </div>
</div>