<% layout("layouts/boilerplate") %>

<div class="max-w-7xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">All Orders</h1>
    <p class="text-sm text-gray-500">Overview of all platform orders</p>
  </div>

  <!-- Grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

    <% orders.forEach(order => { %>

      <div class="bg-white border rounded-xl shadow-sm p-5">

        <!-- Header -->
        <div class="flex justify-between items-start">

          <h3 class="font-semibold text-gray-800 text-lg">
            <%= order.batch?.name || "Deleted Batch" %>
          </h3>

          <!-- Status Badge -->
          <% if(order.status === "pending") { %>
            <span class="text-xs px-2 py-1 rounded-full bg-yellow-100 text-yellow-700">
              pending
            </span>
          <% } else if(order.status === "accepted") { %>
            <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-700">
              accepted
            </span>
          <% } else if(order.status === "completed") { %>
            <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700">
              completed
            </span>
          <% } else { %>
            <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-700">
              rejected
            </span>
          <% } %>

        </div>

        <!-- Body -->
        <div class="mt-4 space-y-1 text-sm text-gray-600">

          <p>
            Buyer:
            <span class="text-gray-800">
              <%= order.buyer.email %>
            </span>
          </p>

          <p>
            Seller:
            <span class="text-gray-800">
              <%= order.seller.email %>
            </span>
          </p>

          <p>
            Quantity:
            <span class="font-medium text-gray-800">
              <%= order.quantityOrdered %>
            </span>
          </p>

        </div>

      </div>

    <% }) %>

  </div>

</div>

<div class="flex justify-center mt-8">
    <div class="flex gap-2 items-center bg-white shadow px-4 py-2 rounded-lg">

        <% if (currentPage > 1) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage-1 %>">
                Prev
            </a>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
            <a class="px-3 py-1 rounded 
                      <%= i === currentPage ? 'bg-blue-600 text-white' : 'hover:bg-gray-100' %>"
               href="?page=<%= i %>">
                <%= i %>
            </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage+1 %>">
                Next
            </a>
        <% } %>

    </div>
</div>