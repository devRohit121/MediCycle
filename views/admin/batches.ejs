<% layout("layouts/boilerplate") %>

<div class="max-w-7xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">All Batches</h1>
    <p class="text-sm text-gray-500">Manage all listed inventory</p>
  </div>

  <!-- Grid -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

    <% batches.forEach(batch => { %>

      <div class="bg-white border rounded-xl shadow-sm p-5 flex flex-col justify-between">

        <!-- Header -->
        <div class="flex justify-between items-start">

          <h3 class="font-semibold text-gray-800 text-lg">
            <%= batch.name %>
          </h3>

          <!-- Status -->
          <% if(batch.status === "Available") { %>
            <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-700">
              Available
            </span>
          <% } else if(batch.status === "Sold") { %>
            <span class="text-xs px-2 py-1 rounded-full bg-gray-200 text-gray-700">
              Sold
            </span>
          <% } else { %>
            <span class="text-xs px-2 py-1 rounded-full bg-yellow-100 text-yellow-700">
              <%= batch.status %>
            </span>
          <% } %>

        </div>

        <!-- Body -->
        <div class="mt-4 space-y-1 text-sm text-gray-600">

          <p>
            Seller:
            <span class="text-gray-800">
              <%= batch.seller?.email || "N/A" %>
            </span>
          </p>

          <p>
            Quantity:
            <span class="font-medium text-gray-800">
              <%= batch.quantity %>
            </span>
          </p>

        </div>

        <!-- Footer -->
        <div class="mt-5">

          <form method="POST"
                action="/admin/batches/<%= batch._id %>?_method=DELETE">

            <button
              class="w-full bg-red-50 text-red-600 py-2 rounded-lg text-sm hover:bg-red-100 transition">
              Delete
            </button>

          </form>

        </div>

      </div>

    <% }) %>

  </div>

</div>

<div class="flex justify-center mt-8">
    <div class="flex gap-2 items-center bg-white shadow px-4 py-2 rounded-lg">

        <% if (currentPage > 1) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage-1 %>">
                Prev
            </a>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
            <a class="px-3 py-1 rounded 
                      <%= i === currentPage ? 'bg-blue-600 text-white' : 'hover:bg-gray-100' %>"
               href="?page=<%= i %>">
                <%= i %>
            </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage+1 %>">
                Next
            </a>
        <% } %>

    </div>
</div>