<% layout("layouts/boilerplate") %>

<div class="max-w-7xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Order History</h1>
    <p class="text-sm text-gray-500">Manage and track all incoming orders</p>
  </div>

  <!-- ================= STATS ================= -->
  <h2 class="text-lg font-semibold text-gray-700 mb-3">Stats</h2>

  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-10">

    <div class="bg-white border rounded-xl p-4 text-center">
      <p class="text-sm text-gray-500">Pending</p>
      <p class="text-xl font-bold text-yellow-600"><%= pending %></p>
    </div>

    <div class="bg-white border rounded-xl p-4 text-center">
      <p class="text-sm text-gray-500">Accepted</p>
      <p class="text-xl font-bold text-green-600"><%= accepted %></p>
    </div>

    <div class="bg-white border rounded-xl p-4 text-center">
      <p class="text-sm text-gray-500">Rejected</p>
      <p class="text-xl font-bold text-red-500"><%= rejected %></p>
    </div>

    <div class="bg-white border rounded-xl p-4 text-center">
      <p class="text-sm text-gray-500">Completed</p>
      <p class="text-xl font-bold text-blue-600"><%= completed %></p>
    </div>

    <div class="bg-white border rounded-xl p-4 text-center">
      <p class="text-sm text-gray-500">Revenue</p>
      <p class="text-xl font-bold text-gray-800">₹<%= totalEarning %></p>
    </div>

  </div>

  <!-- ================= PENDING ================= -->
  <h2 class="text-lg font-semibold text-gray-700 mb-3">Pending Orders</h2>

  <% if (pendingOrders.length > 0) { %>
    <div class="grid md:grid-cols-2 gap-5 mb-10">

      <% for (let order of pendingOrders) { %>

        <div class="bg-white border rounded-xl shadow-sm p-5">

          <div class="flex justify-between">
            <h3 class="font-semibold text-gray-800">
              <%= order.batch ? order.batch.name : "Batch deleted" %>
            </h3>

            <span class="text-xs px-2 py-1 rounded-full bg-yellow-100 text-yellow-700">
              pending
            </span>
          </div>

          <div class="mt-3 space-y-1 text-sm text-gray-600">
            <p>Buyer: <span class="text-gray-800"><%= order.buyer.email %></span></p>
            <p>Quantity: <%= order.quantityOrdered %></p>
            <p>Total: ₹<%= order.totalAmount %></p>
            <p>Ordered: <%= order.createdAt.toDateString() %></p>
          </div>

          <!-- Actions -->
          <div class="mt-4 flex gap-3">

            <form method="POST"
                  action="/orders/<%= order._id %>/status?_method=PUT">
              <input type="hidden" name="status" value="accepted">
              <button class="bg-green-600 text-white px-3 py-2 rounded-lg text-sm hover:bg-green-700">
                Accept
              </button>
            </form>

            <form method="POST"
                  action="/orders/<%= order._id %>/status?_method=PUT">
              <input type="hidden" name="status" value="rejected">
              <button class="bg-red-600 text-white px-3 py-2 rounded-lg text-sm hover:bg-red-700">
                Reject
              </button>
            </form>

          </div>

        </div>

      <% } %>

    </div>
  <% } else { %>
    <p class="text-sm text-gray-500 mb-10">No pending orders</p>
  <% } %>

  <!-- ================= PROCESSED ================= -->
  <h2 class="text-lg font-semibold text-gray-700 mb-3">Processed Orders</h2>

  <% if (processedOrders.length > 0) { %>

    <div class="grid md:grid-cols-2 gap-5 mb-10">

      <% for (let order of processedOrders) { %>

        <div class="bg-white border rounded-xl shadow-sm p-5">

          <div class="flex justify-between">
            <h3 class="font-semibold text-gray-800">
              <%= order.batch ? order.batch.name : "Batch deleted" %>
            </h3>

            <% if(order.status === "accepted") { %>
              <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-700">
                accepted
              </span>
            <% } else { %>
              <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-700">
                rejected
              </span>
            <% } %>
          </div>

          <div class="mt-3 text-sm text-gray-600 space-y-1">
            <p>Buyer: <%= order.buyer.email %></p>
            <p>Quantity: <%= order.quantityOrdered %></p>
            <p>Total: ₹<%= order.totalAmount %></p>
            <p>Ordered: <%= order.createdAt.toDateString() %></p>
          </div>

        </div>

      <% } %>

    </div>

  <% } else { %>
    <p class="text-sm text-gray-500 mb-10">No processed orders</p>
  <% } %>

  <!-- ================= COMPLETED ================= -->
  <h2 class="text-lg font-semibold text-gray-700 mb-3">Completed Orders</h2>

  <% if (completedOrders.length > 0) { %>

    <div class="grid md:grid-cols-2 gap-5">

      <% for (let order of completedOrders) { %>

        <div class="bg-white border rounded-xl shadow-sm p-5 opacity-90">

          <div class="flex justify-between">
            <h3 class="font-semibold text-gray-800">
              <%= order.batch ? order.batch.name : "Batch deleted" %>
            </h3>

            <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700">
              completed
            </span>
          </div>

          <div class="mt-3 text-sm text-gray-600 space-y-1">
            <p>Buyer: <%= order.buyer.email %></p>
            <p>Quantity: <%= order.quantityOrdered %></p>
            <p>Total: ₹<%= order.totalAmount %></p>
            <p>Ordered: <%= order.createdAt.toDateString() %></p>
          </div>

        </div>

      <% } %>

    </div>

  <% } else { %>
    <p class="text-sm text-gray-500">No completed orders</p>
  <% } %>

</div>