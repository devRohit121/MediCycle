<% layout("layouts/boilerplate") %>

<div class="max-w-6xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">
        Hello, <%= currentUser ? currentUser.username : "Guest" %>
      </h1>
      <p class="text-sm text-gray-500">Seller dashboard overview</p>
    </div>

    <% if (currentUser && currentUser.role === "seller") { %>
      <a href="/orders/seller"
         class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700 transition">
        View Orders
      </a>
    <% } %>
  </div>

  <% if (currentUser && currentUser.role === "seller") { %>

    <h2 class="text-lg font-semibold text-gray-700 mb-4">Your Listings</h2>

    <% if (medis && medis.length > 0) { %>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <% for (let medi of medis) { %>

          <div class="bg-white border rounded-xl shadow-sm p-5 flex flex-col justify-between">

            <!-- Top Info -->
            <div>
              <h3 class="font-semibold text-gray-800 text-lg mb-2">
                <%= medi.name %>
              </h3>

              <div class="space-y-1 text-sm text-gray-600">

                <p>Category: <span class="text-gray-800"><%= medi.category %></span></p>
                <p>Manufacturer: <%= medi.manufacturer %></p>
                <p>Batch No: <%= medi.batchNo %></p>

                <p>Qty: <%= medi.quantity %></p>
                <p>Unit Price: ₹<%= medi.unitPrice %></p>

                <p class="text-green-700 font-medium">
                  Discounted: ₹<%= medi.discountedPrice %>
                </p>

                <p>Location: <%= medi.location %></p>

                <p>
                  Expiry:
                  <span class="text-gray-800">
                    <%= medi.expiryDate ? new Date(medi.expiryDate).toDateString() : "N/A" %>
                  </span>
                </p>

              </div>

              <!-- Status -->
              <div class="mt-3">
                <span class="text-xs px-2 py-1 rounded-full
                  <%= medi.status === 'Available'
                    ? 'bg-green-100 text-green-700'
                    : medi.status === 'Expired'
                    ? 'bg-red-100 text-red-700'
                    : medi.status === 'Out of Stock'
                    ? 'bg-yellow-100 text-yellow-700'
                    : 'bg-gray-100 text-gray-700' %>">
                  <%= medi.status %>
                </span>
              </div>
            </div>

            <!-- Actions -->
            <div class="mt-5 flex gap-3">

              <a href="/batches/<%= medi._id %>/edit"
                 class="flex-1 text-center bg-yellow-500 text-white py-2 rounded-lg text-sm hover:bg-yellow-600">
                Edit
              </a>

              <form method="POST"
                    action="/batches/<%= medi._id %>?_method=DELETE"
                    class="flex-1">
                <button type="submit"
                        class="w-full bg-red-500 text-white py-2 rounded-lg text-sm hover:bg-red-600">
                  Delete
                </button>
              </form>

            </div>

          </div>

        <% } %>

      </div>

    <% } else { %>

      <div class="bg-white border rounded-xl p-6 text-sm text-gray-500">
        No Listings found
      </div>

    <% } %>

  <% } %>

</div>

<div class="flex justify-center mt-8">
    <div class="flex gap-2 items-center bg-white shadow px-4 py-2 rounded-lg">

        <% if (currentPage > 1) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage-1 %>">
                Prev
            </a>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
            <a class="px-3 py-1 rounded 
                      <%= i === currentPage ? 'bg-blue-600 text-white' : 'hover:bg-gray-100' %>"
               href="?page=<%= i %>">
                <%= i %>
            </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
            <a class="px-3 py-1 rounded hover:bg-gray-100"
               href="?page=<%= currentPage+1 %>">
                Next
            </a>
        <% } %>

    </div>
</div>